// FamPilot data model — families, members, children, events, tasks, reminders, invites.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  parent
  caregiver
  admin
}

enum EventType {
  school
  health
  activity
  social
  other
}

enum EventStatus {
  draft
  confirmed
  cancelled
}

enum EventSource {
  manual
  ai_capture
  assistant
}

enum TaskStatus {
  todo
  doing
  done
}

enum Recurrence {
  none
  daily
  weekly
}

enum ReminderChannel {
  push
  email
}

enum ReminderState {
  scheduled
  sent
  dismissed
  snoozed
}

enum ConnectorType {
  gmail
  whatsapp
}

model Family {
  id         String      @id
  name       String
  timezone   String      @default("UTC")
  locale     String      @default("en")
  createdAt  DateTime    @default(now())
  users      User[]
  children   Child[]
  events     Event[]
  tasks      Task[]
  invites    Invite[]
  connectors Connector[]
  listItems  ListItem[]
  meals      Meal[]
}

model User {
  id            String     @id
  familyId      String
  family        Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  name          String
  email         String?    @unique
  phone         String?
  role          MemberRole @default(parent)
  color         String?
  avatarUrl     String?
  pushToken     String?
  passwordHash  String?
  createdAt     DateTime   @default(now())
  ownedEvents   Event[]    @relation("owner")
  assignedTasks Task[]     @relation("assignee")

  @@index([familyId])
}

model Child {
  id        String    @id
  familyId  String
  family    Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  name      String
  dob       DateTime?
  school    String?
  notes     String?
  createdAt DateTime  @default(now())
  events    Event[]

  @@index([familyId])
}

model Event {
  id                String      @id
  familyId          String
  family            Family      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  startTime         DateTime
  endTime           DateTime?
  allDay            Boolean     @default(false)
  location          String?
  type              EventType   @default(other)
  recur             Recurrence  @default(none)
  childId           String?
  child             Child?      @relation(fields: [childId], references: [id], onDelete: SetNull)
  ownerId           String?
  owner             User?       @relation("owner", fields: [ownerId], references: [id], onDelete: SetNull)
  status            EventStatus @default(confirmed)
  source            EventSource @default(manual)
  reminderOffsetMin Int?
  createdAt         DateTime    @default(now())
  reminders         Reminder[]

  @@index([familyId, startTime])
  @@index([ownerId])
  @@index([childId])
}

model Task {
  id              String     @id
  familyId        String
  family          Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  dueDate         DateTime?
  status          TaskStatus @default(todo)
  recur           Recurrence @default(none)
  priority        Int        @default(0)
  assigneeId      String?
  assignee        User?      @relation("assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  suggested       Boolean    @default(false)
  suggestedReason String?
  linkedEventId   String?
  createdAt       DateTime   @default(now())
  reminders       Reminder[]

  @@index([familyId, status])
  @@index([assigneeId])
}

model Reminder {
  id            String          @id
  familyId      String
  eventId       String?
  event         Event?          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  taskId        String?
  task          Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  targetUserId  String?
  remindAt      DateTime
  offsetMinutes Int?
  channel       ReminderChannel @default(push)
  state         ReminderState   @default(scheduled)
  jobId         String?
  createdAt     DateTime        @default(now())

  @@index([remindAt])
}

model Invite {
  id         String     @id
  familyId   String
  family     Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  token      String     @unique
  email      String?
  role       MemberRole @default(parent)
  invitedBy  String?
  acceptedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime   @default(now())

  @@index([familyId])
}

model Connector {
  id           String        @id
  familyId     String
  family       Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  type         ConnectorType
  email        String?
  accessToken  String?
  refreshToken String?
  expiryDate   DateTime?
  historyId    String?
  lastSyncedAt DateTime?
  createdAt    DateTime      @default(now())

  @@index([familyId])
}

model ProcessedEmail {
  id        String   @id
  familyId  String
  messageId String
  createdAt DateTime @default(now())

  @@unique([familyId, messageId])
}

model ListItem {
  id        String   @id
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  list      String   @default("shopping")
  title     String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([familyId, list])
}

model Meal {
  id       String   @id
  familyId String
  family   Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  date     DateTime
  slot     String   @default("dinner")
  title    String

  @@index([familyId, date])
}
